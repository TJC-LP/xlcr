<configuration>
    <!-- Console appender routes to STDERR to keep stdout clean for structured
         CLI output (JSON, XML, converted bytes). -->
    <appender name="STDERR" class="ch.qos.logback.core.ConsoleAppender">
        <target>System.err</target>
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- File appender. Set XLCR_LOG_FILE=/dev/null to disable (ephemeral containers). -->
    <appender name="FILE" class="ch.qos.logback.core.FileAppender">
        <file>${XLCR_LOG_FILE:-logs/application.log}</file>
        <append>true</append>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Root level controlled by XLCR_LOG_LEVEL env var (default: INFO). -->
    <root level="${XLCR_LOG_LEVEL:-INFO}">
        <appender-ref ref="STDERR" />
        <appender-ref ref="FILE" />
    </root>
</configuration>
